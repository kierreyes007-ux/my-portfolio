  const [todos, setTodo] = useState(()=> {
      const saved = localStorage.getItem("todos");
      return saved ? JSON.parse(saved) : [];
    });
    useEffect(() => {
      localStorage.setItem("todos", JSON.stringify(todos));
    }, [todos])
    const [text, setText] = useState("");
    const [selectedTodo, setSelectedTodo] = useState(null);
    const [currentIndex, setCurrentIndex] = useState(-1);
    const [editText, setEditText] = useState("");
    const [editingIndex, setEditingIndex] = useState(null);
    const addBtn = () => {
      setTodo([...todos, {name: text, status: false}]);
      setText("");
    }
    const selectBtn = () => {
      if(todos.length === 0) return
      let nextIndex = currentIndex + 1;
      if(nextIndex >= todos.length){
        nextIndex = 0;
      }
      setCurrentIndex(nextIndex);
      setSelectedTodo(todos[nextIndex]);
    }
    const markBtn = () => {
      if(!selectedTodo) return;
      setTodo(todos.map((task) => task === selectedTodo ? {...task, status: true} : task))
      setSelectedTodo(null)
    }
    const clearBtn = () => {
      setTodo([]);
      setCurrentIndex(-1);
      setSelectedTodo(null);
    }
  return (
   
    <div className="h-screen w-screen flex items-center justify-center">
    
      <div className="TodoCase grid gap-2">
        <div className="todoList">
          {todos.length === 0 ? (<p>No Task</p>) : (<> <p>Task:</p>
          {todos.map((task, index) => (
  <div className="flex justify-between border-2 p-2 pr-5 rounded-2xl" key={index}>
    {editingIndex === index ? (
      <>
        <input
          value={editText}
          onChange={(e) => setEditText(e.target.value)}
        />

        <button
          onClick={() => {
            setTodo(
              todos.map((t, i) =>
                i === index ? { ...t, name: editText } : t
              )
            );

            setEditingIndex(null);
            setEditText("");
          }}
        >
          Save
        </button>
      </>
    ) : (
      <>
        <p className="mr-4">
          {index + 1}. {task.name} - {task.status ? "Done" : "Not Done"}
        </p>

        <button
          onClick={() => {
            setEditingIndex(index);
            setEditText(task.name);
          }}
        >
          Edit
        </button>
      </>
    )}
  </div>
))}
          </>)}
        </div>
        <div className="todoInfo">
          {selectedTodo ? (<>
          <p>Selected Task: {selectedTodo.name}</p>
          <p>Status: {selectedTodo.status ? "Done" : "Not Done"}</p></>) : (
            <p>No Selected Task</p>
          )}
        </div>
        <input type="text" value={text} onChange={(e) => setText(e.target.value)}></input>
        <button onClick={addBtn}>Add</button>
        <button onClick={selectBtn}>Select</button>
        <button onClick={markBtn}>Mark as Done</button>
        <button onClick={clearBtn}>Clear All</button>
      </div>
    </div> )


    {DEBOUNCING}
    import { useState, useEffect} from "react";

function Todo() {
  const [text, setText] = useState("");
  const [debounce, setDebounce] = useState("");
  useEffect(()=>{
    const timer = setTimeout(() => {
      setDebounce(text)
    }, 500 )
    return () => clearInterval(timer);
  }, [text])
  return (
    <div className="w-full h-screen flex flex-col justify-center items-center">
      <p>{text}</p>
      <p>{debounce}</p>
      <input className="border-2" value={text} onChange={(e) => setText(e.target.value)}></input>
    </div>
  )
  
}
export default Todo;